# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Forking historical blocks requires ARCHIVE nodes — free public RPCs
# usually only keep recent state and will fail with "missing trie node".

# --- Archive RPC endpoints (one per chain you analyze) ---
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.bnbchain.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# --- Etherscan V2: single key, all chains ---
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_V2_KEY
